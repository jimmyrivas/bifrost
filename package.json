{
  "name": "bifrost",
  "version": "0.2.0",
  "description": "Modern connection manager for Linux — spiritual successor to Ásbrú Connection Manager",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Jimmy Rivas",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3 node-pty",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package": "electron-vite build && electron-builder --linux",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "mcp:dev": "npx tsx src/mcp/index.ts",
    "mcp:http": "BIFROST_MCP_HTTP=1 npx tsx src/mcp/index.ts",
    "mcp:build": "tsc -p tsconfig.mcp.json",
    "mcp:start": "node out/mcp/index.js",
    "mcp:install": "node -e \"const p=require('path'),h=require('os').homedir();const c=p.join(h,'.claude','settings.json');let s={};try{s=JSON.parse(require('fs').readFileSync(c,'utf8'))}catch{}if(!s.mcpServers)s.mcpServers={};s.mcpServers.bifrost={command:'npx',args:['tsx',p.resolve('src/mcp/index.ts')]};require('fs').writeFileSync(c,JSON.stringify(s,null,2));console.log('Bifrost MCP server registered in Claude Code settings')\""
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "i18next": "^24.2.0",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-resizable-panels": "^2.1.0",
    "sql.js": "1.14.1",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "zod": "4.3.6",
    "zustand": "^5.0.12"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "1.4.11",
    "@types/ssh2": "^1.15.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
